{
    "name": "@rel-packages/osu-beatmap-preview",
    "version": "0.11.0",
    "description": "one of the beatmap preview of all time",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "update:patch": "bun run format && npm version patch && git push --follow-tags",
        "update:minor": "bun run format && npm version minor && git push --follow-tags",
        "update:major": "bun run format && npm version major && git push --follow-tags",
        "dev": "bun run --watch src/index.ts",
        "example:build": "cd example && bun run build",
        "build": "bun run scripts/build.ts",
        "lint": "eslint src tests scripts --ext .ts,.js --max-warnings=0",
        "test": "bun test",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "tsc --noEmit -p src/tsconfig.json",
        "check": "bun run format:check && bun run lint && bun run test && bun run type-check",
        "ci": "bun run check && bun run build && bun run example:build",
        "example": "cd example && bun run dev",
        "generate:skin": "bun run src/scripts/generate_skin_manifest.ts"
    },
    "dependencies": {
        "@rel-packages/osu-beatmap-parser": "^1.5.6",
        "jszip": "^3.10.1",
        "pixi.js": "^7.4.3"
    },
    "devDependencies": {
        "@types/bun": "^1.1.0",
        "@typescript-eslint/eslint-plugin": "^8.46.0",
        "@typescript-eslint/parser": "^8.46.0",
        "eslint": "^9.38.0",
        "globals": "^16.4.0",
        "prettier": "^3.7.4",
        "prettier-plugin-svelte": "^3.4.0",
        "typescript": "^5.3.0"
    },
    "author": "rel",
    "license": "ISC",
    "repository": {
        "url": "https://github.com/mezleca/osu-beatmap-preview.git"
    }
}
